# ==========================================
# Swasthya Sahayak - Environment Variables
# ==========================================
# Copy this file to .env and fill in your values

# Backend API URL (for frontend)
VITE_API_URL=http://localhost:8080/api

# OpenAI API Key (for AI chat responses)
VITE_OPENAI_API_KEY=sk-your-openai-api-key-here

# MongoDB Connection String (for Spring Boot backend)
# Used in: backend/src/main/resources/application.properties
# Format: mongodb://localhost:27017/swasthya_sahayak

# JWT Secret (for Spring Boot backend)
# Use a long, random string (at least 256 bits)
# JWT_SECRET=your-super-secret-jwt-key-change-this

# Google Places API Key (for nearby hospitals)
# GOOGLE_API_KEY=your-google-places-api-key-here
